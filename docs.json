{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sun API",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/images/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "文档",
        "groups": [
          {
            "group": "快速开始",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          }
        ]
      },
      {
        "tab": "API 参考",
        "openapi": {
          "source": "api-reference/relay.json",
          "directory": "api-reference"
        }
      },
      {
        "tab": "管理 API",
        "openapi": {
          "source": "api-reference/api.json",
          "directory": "admin-api"
        }
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/upseem/sun-api-docs",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "管理后台",
        "href": "https://api.sunx.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "开始使用",
      "href": "https://api.sunx.ai/register"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/upseem/sun-api-docs"
    }
  }
}
