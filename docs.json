{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sun API",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/images/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "快速开始",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "API 参考",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "对话接口",
            "pages": [
              "api-reference/chat/create-chat-completion",
              "api-reference/chat/create-message",
              "api-reference/chat/generate-content"
            ]
          },
          {
            "group": "图像与视频",
            "pages": [
              "api-reference/images/create-image",
              "api-reference/images/edit-image",
              "api-reference/videos/create-video",
              "api-reference/videos/get-video-task"
            ]
          },
          {
            "group": "音频接口",
            "pages": [
              "api-reference/audio/transcriptions",
              "api-reference/audio/speech"
            ]
          },
          {
            "group": "其他接口",
            "pages": [
              "api-reference/embeddings/create-embedding",
              "api-reference/rerank/create-rerank",
              "api-reference/models/list-models"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/upseem/sun-api-docs",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "api": {
    "openapi": [
      "api-reference/relay.json"
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "管理后台",
        "href": "https://your-domain.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "开始使用",
      "href": "https://your-domain.com/register"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/upseem/sun-api-docs"
    }
  }
}